{
  "name": "@launchctrl/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^9.3.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/swagger": "^8.14.0",
    "@launchctrl/config": "workspace:*",
    "@launchctrl/domain": "workspace:*",
    "@launchctrl/integrations": "workspace:*",
    "@launchctrl/lib": "workspace:*",
    "@launchctrl/skills": "workspace:*",
    "@launchctrl/templates": "workspace:*",
    "@launchctrl/types": "workspace:*",
    "@launchctrl/userbot-agent": "workspace:^",
    "bullmq": "^5.4.0",
    "drizzle-orm": "^0.30.0",
    "fastify": "^4.26.0",
    "ioredis": "^5.3.2",
    "nanoid": "^5.0.7",
    "pg": "^8.11.3",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@types/pg": "^8.11.4",
    "drizzle-kit": "^0.20.17",
    "tsc-alias": "^1.8.8",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5",
    "vitest": "^1.5.0"
  }
}
