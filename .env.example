# ============================================================
# LaunchCtrl Environment Variables
# Copy to .env and fill in values. NEVER commit .env to git.
# ============================================================

# ---- Node ----
NODE_ENV=development

# ---- API ----
API_PORT=3001
API_HOST=0.0.0.0

# ---- Bot ----
BOT_PORT=3002
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_BOT_WEBHOOK_SECRET=random_32_char_string
TELEGRAM_MINI_APP_URL=https://your-miniapp-url.com

# ---- Mini App ----
MINIAPP_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_BOT_USERNAME=your_bot_username

# ---- Database ----
DATABASE_URL=postgresql://launchctrl:launchctrl@localhost:5432/launchctrl

# ---- Redis ----
REDIS_URL=redis://localhost:6379

# ---- Auth / JWT ----
JWT_SECRET=replace_with_64_char_random_hex_string_minimum
JWT_EXPIRY=7d
SESSION_COOKIE_NAME=lc_session

# ---- Telegram ----
# Your bot's token from @BotFather
TELEGRAM_BOT_TOKEN=
# Hash salt for init data HMAC
TELEGRAM_INIT_DATA_MAX_AGE_SECONDS=86400

# ---- Encryption ----
# AES-256 key for encrypting stored secrets (32 bytes hex = 64 hex chars)
ENCRYPTION_KEY=replace_with_64_char_hex_string

# ---- Rate Limiting ----
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ---- Observability ----
LOG_LEVEL=info
TELEMETRY_ENABLED=false
SENTRY_DSN=

# ---- Feature Flags ----
FEATURE_WILD_MODE=false
FEATURE_ADVANCED_AUTOMATION=false

# ---- Admin ----
ADMIN_SECRET=replace_with_strong_random_secret
